# ==========================================
# NeuroSense Advanced Configuration
# ==========================================

# ==========================================
# API Keys (Required for AI Features)
# ==========================================

# Google Gemini API Key (Used by Chatbot & AI Assistant)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq API Key (Optional Alternative for Chatbot)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# ==========================================
# Security Configuration
# ==========================================

# Flask Secret Key (For User Sessions & Login) - CRITICAL for production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE

# ==========================================
# Application Settings
# ==========================================
FLASK_ENV=development
FLASK_DEBUG=0
APP_VERSION=1.0.0

# ==========================================
# CORS Configuration (Comma-separated list)
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=INFO
LOG_FORMAT=text  # Options: text, json
# LOG_FILE=/var/log/neurosense/app.log  # Optional file logging

# ==========================================
# Rate Limiting Configuration
# ==========================================
# Storage URI for rate limiter (memory:// for single instance, redis:// for distributed)
RATELIMIT_STORAGE=memory://
# For Redis (recommended for production):
# RATELIMIT_STORAGE=redis://localhost:6379

# ==========================================
# Redis Configuration (for Celery)
# ==========================================
REDIS_URL=redis://localhost:6379/0

# ==========================================
# Observability Configuration
# ==========================================

# Sentry Error Tracking (Optional - highly recommended for production)
# Get yours at: https://sentry.io
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# MLflow Experiment Tracking (Optional)
# MLFLOW_TRACKING_URI=http://localhost:5001

# ==========================================
# Data Retention
# ==========================================
DATA_RETENTION_DAYS=90

# ==========================================
# File Upload Configuration
# ==========================================
# MAX_CONTENT_LENGTH=16777216  # 16MB in bytes (default is already set to 16MB)

# ==========================================
# Database Configuration (for PostgreSQL migration)
# ==========================================
# For SQLite (development - default):
# DATABASE_URL=sqlite:///patient_data.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/neurosense
# POSTGRES_PASSWORD=your_secure_password
